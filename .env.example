# MySQL container settings
MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_DATABASE_GAME=chess_game_db
MYSQL_DATABASE_AUTH=chess_auth_db
MYSQL_DATABASE_ROOM=chess_room_db
MYSQL_USER=chess_user
MYSQL_PASSWORD=change-user-password

# Application database connection
DATABASE_URL_GAME=mysql+pymysql://chess_user:change-user-password@game-db:3306/chess_game_db
DATABASE_URL_AUTH=mysql+pymysql://chess_user:change-user-password@auth-db:3306/chess_auth_db
DATABASE_URL_ROOM=mysql+pymysql://chess_user:change-user-password@room-db:3306/chess_room_db

# JWT settings
JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256

# Redis settings
REDIS_URL=redis://redis:6379/0